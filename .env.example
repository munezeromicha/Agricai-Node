# Contact form (existing)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# MAIL_TO=
# MAIL_FROM=

# Gemini chat (Google AI Studio API key — never commit real keys)
GEMINI_API_KEY=
# Default in code is gemini-2.5-flash. Avoid gemini-flash-latest — often returns 503 "high demand".
# GEMINI_MODEL=gemini-2.5-flash
# Gemini HTTP: force IPv4 + longer connect timeout (fixes "fetch failed" on some Windows networks)
GEMINI_CONNECT_TIMEOUT_MS=60000
GEMINI_HEADERS_TIMEOUT_MS=120000
# Other options: gemini-2.0-flash, gemini-2.5-flash-lite
# Optional: smaller = fewer input tokens per request (helps free-tier per-minute limits)
# GEMINI_CLASSES_MAX_CHARS=6000
# GEMINI_PROJECT_MAX_CHARS=12000

# Knowledge files (defaults: ../Agricai-Python/data/classes.json and ./data/project-knowledge.md)
# CLASSES_JSON_PATH=../Agricai-Python/data/classes.json
# PROJECT_KNOWLEDGE_PATH=./data/project-knowledge.md
# Edit data/project-knowledge.md for founders, contact, mission — see docs/HOW-TO-FEED-DATA-TO-CHAT.md

PORT=3008
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173,https://agric-ai.com,https://www.agric-ai.com

# Auth & database (JSON file store by default)
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=12
DATABASE_PATH=./data/store.json
FARMER_SCANS_PER_DAY=10
FARMER_CHATS_PER_DAY=10

# SuperAdmin account (created on first server start if not exists)
SUPERADMIN_EMAIL=admin@agric-ai.com
SUPERADMIN_PASSWORD=change-me-superadmin
SUPERADMIN_NAME=Super Admin

# Weather proxy
OPEN_METEO_BASE=https://api.open-meteo.com/v1/forecast
WEATHER_CACHE_TTL_SEC=900

# Crops catalog
CROPS_JSON_PATH=./data/crops.json

# Stripe billing (stub mode when unset)
BILLING_STUB_MODE=true
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
