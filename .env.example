# Contact form (existing)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# MAIL_TO=
# MAIL_FROM=

# Gemini chat (Google AI Studio API key — never commit real keys)
GEMINI_API_KEY=
# Default in code is gemini-2.5-flash (gemini-1.5-flash → 404 on current API).
# Alternatives: gemini-flash-latest, gemini-3-flash-preview, gemini-2.5-flash-lite
# GEMINI_MODEL=gemini-2.5-flash
# Optional: smaller = fewer input tokens per request (helps free-tier per-minute limits)
# GEMINI_CLASSES_MAX_CHARS=6000

PORT=3008
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173
